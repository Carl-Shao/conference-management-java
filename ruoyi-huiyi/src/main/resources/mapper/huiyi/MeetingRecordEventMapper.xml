<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.huiyi.mapper.MeetingRecordEventMapper">

    <resultMap type="com.ruoyi.huiyi.domain.MeetingRecordEvent" id="MeetingRecordEventResult">
        <id     property="id"        column="id"/>
        <result property="meetingId" column="meeting_id"/>
        <result property="eventType" column="event_type"/>
        <result property="eventTime" column="event_time"/>
        <result property="operator"  column="operator"/>
        <result property="remark"    column="remark"/>
    </resultMap>

    <insert id="insertMeetingRecordEvent" parameterType="com.ruoyi.huiyi.domain.MeetingRecordEvent"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO meeting_record_event (meeting_id, event_type, event_time, operator, remark)
        VALUES (#{meetingId}, #{eventType}, #{eventTime}, #{operator}, #{remark})
    </insert>

</mapper>