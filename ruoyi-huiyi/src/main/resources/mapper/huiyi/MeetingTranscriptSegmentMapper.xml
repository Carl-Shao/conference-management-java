<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.huiyi.mapper.MeetingTranscriptSegmentMapper">

    <resultMap type="com.ruoyi.huiyi.domain.MeetingTranscriptSegment" id="MeetingTranscriptSegmentResult">
        <id     property="id"            column="id"/>
        <result property="meetingId"     column="meeting_id"/>
        <result property="seqNo"         column="seq_no"/>
        <result property="startOffsetMs" column="start_offset_ms"/>
        <result property="endOffsetMs"   column="end_offset_ms"/>
        <result property="text"          column="text"/>
        <result property="createTime"    column="create_time"/>
    </resultMap>

    <insert id="insertSegment" parameterType="com.ruoyi.huiyi.domain.MeetingTranscriptSegment"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO meeting_transcript_segment
        (meeting_id, seq_no, start_offset_ms, end_offset_ms, text, create_time)
        VALUES
        (#{meetingId}, #{seqNo}, #{startOffsetMs}, #{endOffsetMs}, #{text}, NOW())
    </insert>

    <select id="selectSegmentsByMeetingId" parameterType="Long" resultMap="MeetingTranscriptSegmentResult">
        SELECT id, meeting_id, seq_no, start_offset_ms, end_offset_ms, text, create_time
        FROM meeting_transcript_segment
        WHERE meeting_id = #{meetingId}
        ORDER BY seq_no ASC
    </select>

</mapper>